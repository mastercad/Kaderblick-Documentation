<!DOCTYPE html>
<html lang="de">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}docs.kaderblick.de{% endblock %}</title>
        <link rel="icon" href="favicon.ico" type="image/x-icon">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
        <link rel="preload" href="/fonts/ImpactLTStd.woff2" as="font" type="font/woff2" crossorigin />
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('css/variables.css') }}">
            <link rel="stylesheet" href="{{ asset('css/layout.css') }}">
            <link rel="stylesheet" href="{{ asset('css/header.css') }}">
            <link rel="stylesheet" href="{{ asset('css/sidebar.css') }}">
            <link rel="stylesheet" href="{{ asset('css/content.css') }}">
            <link rel="stylesheet" href="{{ asset('css/components.css') }}">
            <link rel="stylesheet" href="{{ asset('css/responsive.css') }}">
        {% endblock %}
        {# Google model-viewer Web Component für GLB-3D-Ansichten #}
        <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.5.0/model-viewer.min.js"></script>
        {# Three.js für OBJ-Dateien (Import Map + Module) #}
        <script type="importmap">
        {
            "imports": {
                "three": "https://cdn.jsdelivr.net/npm/three@0.164.1/build/three.module.js",
                "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.164.1/examples/jsm/"
            }
        }
        </script>
    </head>
    <body>
        {# ─── Header ─── #}
        <header class="site-header">
            <button class="sidebar-toggle" onclick="toggleSidebar()" aria-label="Menü öffnen">☰</button>
            <a href="{{ path('app_home') }}" class="site-header__logo">
                <span class="site-header__logo_text"><span class="site-header__logo_highlight">K</span>ADERBLICK</span>
                <span class="site-header__badge">Docs</span>
            </a>
        </header>

        <div class="site-layout">
            {# ─── Sidebar Overlay (Mobile) ─── #}
            <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

            {# ─── Sidebar ─── #}
            <aside class="sidebar" id="sidebar">
                <div class="sidebar__section-title">Dokumentation</div>
                <ul class="sidebar__nav">
                    {% for route, item in navigation %}
                        <li>
                            <a href="{{ path(route) }}"
                               class="sidebar__link {{ active_route == route ? 'sidebar__link--active' : '' }}">
                                <span class="sidebar__link-icon">{{ item.icon }}</span>
                                {{ item.label }}
                            </a>
                        </li>
                    {% endfor %}
                </ul>

                {% if tools_navigation is defined and tools_navigation is not empty %}
                    <div class="sidebar__section-title sidebar__section-title--tools">Tools & Equipment</div>
                    <ul class="sidebar__nav">
                        {% for route, item in tools_navigation %}
                            <li>
                                <a href="{{ path(route) }}"
                                   class="sidebar__link {{ active_route == route ? 'sidebar__link--active' : '' }}">
                                    <span class="sidebar__link-icon">{{ item.icon }}</span>
                                    {{ item.label }}
                                </a>
                                {% if item.children is defined %}
                                    <ul class="sidebar__nav sidebar__nav--children">
                                        {% for child_route, child in item.children %}
                                            <li>
                                                <a href="{{ path(child_route) }}"
                                                   class="sidebar__link sidebar__link--child {{ active_route == child_route ? 'sidebar__link--active' : '' }}">
                                                    <span class="sidebar__link-icon">{{ child.icon }}</span>
                                                    {{ child.label }}
                                                </a>
                                            </li>
                                        {% endfor %}
                                    </ul>
                                {% endif %}
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </aside>

            {# ─── Content ─── #}
            <main class="site-content">
                {% block body %}{% endblock %}
            </main>
        </div>

        <footer class="site-footer">
            &copy; {{ 'now'|date('Y') }} docs.kaderblick.de &middot; Teil von
            <a href="https://kaderblick.de" target="_blank">kaderblick.de</a>
        </footer>

        <script>
            function toggleSidebar() {
                document.getElementById('sidebar').classList.toggle('sidebar--open');
                document.getElementById('sidebarOverlay').classList.toggle('sidebar-overlay--visible');
            }

            /* Sidebar-Scrollposition über Seitenwechsel hinweg beibehalten */
            (function () {
                const sidebar = document.getElementById('sidebar');
                const STORAGE_KEY = 'sidebar_scroll';

                /* Gespeicherte Position wiederherstellen */
                const saved = sessionStorage.getItem(STORAGE_KEY);
                if (saved !== null) {
                    sidebar.scrollTop = parseInt(saved, 10);
                }

                /* Position vor dem Verlassen der Seite speichern */
                window.addEventListener('beforeunload', function () {
                    sessionStorage.setItem(STORAGE_KEY, sidebar.scrollTop);
                });
            })();
        </script>
    </body>
</html>
